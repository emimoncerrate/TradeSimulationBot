# =============================================================================
# TradeSimulator - DynamoDB Configuration Sample
# =============================================================================
# Copy these settings to your .env file to use DynamoDB instead of mock mode

# APPLICATION SETTINGS
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG_MODE=true

# =============================================================================
# DYNAMODB CONFIGURATION - LOCAL
# =============================================================================
# These settings enable local DynamoDB instead of mock mode
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=us-east-1
DYNAMODB_LOCAL_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_PREFIX=slack-trading-bot

# =============================================================================
# SLACK CONFIGURATION (use your existing values)
# =============================================================================
SLACK_BOT_TOKEN=your-slack-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=your-app-token-here

# MARKET DATA (use your existing value)
FINNHUB_API_KEY=your-finnhub-api-key-here

# SECURITY (use your existing value)
APPROVED_CHANNELS=your-channel-id-here

# =============================================================================
# TRADING SYSTEM
# =============================================================================
MOCK_EXECUTION_ENABLED=true
EXECUTION_DELAY_SECONDS=1.0
MAX_POSITION_SIZE=10000
MAX_TRADE_VALUE=1000000.0
SUPPORTED_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA,META,NVDA,NFLX,SPY,QQQ

# SESSION & SECURITY
SESSION_TIMEOUT_MINUTES=480
MAX_FAILED_ATTEMPTS=5

